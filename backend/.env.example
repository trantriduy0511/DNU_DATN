PORT=5000
MONGODB_URI=mongodb://localhost:27017/dnu-social
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d
NODE_ENV=development

# Gemini AI (Google Generative AI)
# Lấy API key tại: https://aistudio.google.com/api-keys
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-2.5-flash

# Email Configuration (Gmail khuyến nghị dùng App Password)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# Frontend URL
FRONTEND_URL=http://localhost:5173
# Allowed origins (comma-separated) for CORS
# Example: CORS_ORIGINS=http://localhost:5173,https://app.example.com
CORS_ORIGINS=http://localhost:5173
# Reverse proxy trust mode for Express.
# Examples:
# - TRUST_PROXY=false  (local/default)
# - TRUST_PROXY=1      (single reverse proxy, e.g. Nginx/Render/Fly)
# - TRUST_PROXY=loopback
TRUST_PROXY=false

# Rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=25
AI_RATE_LIMIT_WINDOW_MS=900000
AI_RATE_LIMIT_MAX=40

# Redis + BullMQ (AI queue)
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_URL=redis://127.0.0.1:6379
AI_QUEUE_CONCURRENCY=2

